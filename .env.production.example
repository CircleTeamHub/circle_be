# circle_be 生产/测试环境配置模板。
# 用法:复制为 .env.production,把所有 __XXX__ 占位换成真实值。
# docker-compose 会把 .env.production 挂载到容器 /app/.env.production。
# ⚠️ getServerConfig 只读此文件、不读环境变量,所以配置必须写在这里。
# ⚠️ .env.production 含密钥,切勿提交(.gitignore / .dockerignore 已排除 .env*)。

NODE_ENV=production

# ── 数据库(容器内 postgres 服务)────────────────────────────────
# 主机名用 compose 服务名 postgres;密码须与 compose 的 DB_PASSWORD 一致
DATABASE_URL="postgresql://circle:__DB_PASSWORD__@postgres:5432/circle?schema=public"
# 连接池。DATABASE_POOL_MAX × 实例数须低于 Postgres max_connections(默认 100),
# 给迁移和 psql 留余量;蓝绿发版期间两色同时在跑,按 2 倍算。
# DATABASE_POOL_ACQUIRE_TIMEOUT_MS 是等待空闲连接的上限 —— pg 默认无限等待,
# 池打满就变成请求挂死。
# DATABASE_POOL_MAX=10
# DATABASE_POOL_ACQUIRE_TIMEOUT_MS=10000

# ── Redis(内置模式;容器内服务,不暴露公网端口)────────────────────
# 密码须与 compose 的 REDIS_PASSWORD 一致;特殊字符需 URL 编码。
# 托管模式改成 rediss://default:<PASSWORD>@<HOST>:<PORT>,并设置
# REDIS_ALLOW_INSECURE=false;同时从 .env 的 COMPOSE_PROFILES 移除 bundled-redis。
REDIS_URL="redis://default:__REDIS_PASSWORD__@redis:6379"
REDIS_ALLOW_INSECURE=true
REDIS_REQUIRED=false

# ── 鉴权密钥(生产必填,≥32 字符)────────────────────────────────
# 生成:openssl rand -base64 48
SECRET="__REPLACE_32PLUS_RANDOM__"
JWT_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=30d
# 管理台会话(#91):access 默认 15m、refresh 默认 12h(上限被 REFRESH_EXPIRES_IN 钳制)
# ADMIN_JWT_EXPIRES_IN=15m
# ADMIN_REFRESH_EXPIRES_IN=12h

# ── 临时聊天分享链接签名(生产必填,≥32 字符)──────────────────────
# 即使不用临时聊天功能也必须给一个随机串,否则启动校验失败
TEMP_CHAT_LINK_SECRET="__REPLACE_32PLUS_RANDOM__"

# ── 邮件投递(生产强烈建议,#82)────────────────────────────────────
# 不配 SMTP_HOST 时验证码只打到服务器日志,任何真实用户都收不到验证码,
# 注册/验证码登录完全不可用(启动时会打 error 级日志提醒)。
# 设了 SMTP_HOST 就必须配 SMTP_USER/SMTP_PASS,否则启动校验失败。
# 465=隐式 TLS(默认);用 587 时设 SMTP_SECURE=false(自动强制 STARTTLS)。
# 163 邮箱示例: host=smtp.163.com, user=你的账号, pass=客户端授权码(不是登录密码)
# 阿里云个人版: host=smtp.qiye.aliyun.com
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=example@163.com
# SMTP_PASS=__SMTP_AUTH_CODE__
# MAIL_FROM="风信 <example@163.com>"

# ── CORS(生产必填)──────────────────────────────────────────────
# 原生 app 请求无 Origin 头,会被自动放行,不受此项影响。
# 与生产 Admin Web 域名一致;多个来源用逗号分隔。
ALLOWED_ORIGINS=https://admin.example.com

# ── 服务端口 ────────────────────────────────────────────────────
APP_PORT=3000

# ── 日志 ────────────────────────────────────────────────────────
LOG_ON=true
LOG_LEVEL=info
TIMESTAMP=true
HTTP_LOG_ON=true
SLOW_REQUEST_MS=1000
BUSINESS_LOG_ON=true
EXTERNAL_LOG_ON=true
RATE_LIMIT_LOG_ON=true

# ── /metrics 保护(建议设置,否则暴露路由清单/业务指标)──────────────
METRICS_AUTH_TOKEN=__REPLACE_RANDOM__

# ── 对象存储 MinIO(容器内 minio 服务)──────────────────────────────
# 上传模块(头像/图片)需要。PUBLIC_URL 用服务器公网 IP,让 app 能下载图片。
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=__MINIO_ROOT_USER__
MINIO_SECRET_KEY=__MINIO_ROOT_PASSWORD__
MINIO_BUCKET=circle
MINIO_PUBLIC_URL=https://__API_DOMAIN__

# ── OpenIM(阶段5 部署 OpenIM 后填)──────────────────────────────────
# 后端 → OpenIM 的服务端调用：同机走回环，不出网，明文即可。
# 填了 OPENIM_API_URL 就必须填 OPENIM_ADMIN_SECRET（生产 ≥32 字符），否则启动校验失败。
# 该密钥可换取 IM 管理员令牌，切勿沿用 OpenIM 默认值 openIM123。生成：openssl rand -base64 48
# OPENIM_API_URL=http://host.docker.internal:10002
# OPENIM_ADMIN_SECRET=__REPLACE_32PLUS_RANDOM__
#
# 返回给客户端的 IM 地址 —— 必须 TLS 且经 Caddy 反代，不能给公网裸 IP：
#   1) OpenIM 协议把 IM token 放在 WS 握手 URL 的 query 里（msggateway 只从 query 读
#      token，没有 header 通道）。走明文 ws:// 等于把「可直接冒充该用户收发消息」的
#      token 裸奔在公网上，路径上任何人都能捡。
#   2) temp-chat-web 访客页是 HTTPS，浏览器强制拒绝从 https 页面连 ws://。
#   3) 裸 IP 签不了 Let's Encrypt 证书 —— 这也是上线必须先有域名的原因。
# 路径对应 deploy/Caddyfile.admin 的 handle_path（temp-chat-web 用同一套约定）。
# OPENIM_IM_WS_URL=wss://__API_DOMAIN__/openim-ws
# OPENIM_IM_API_URL=https://__API_DOMAIN__/openim-api

# ── LiveKit Cloud 音视频(阶段6 注册 LiveKit Cloud 后填)──────────────
# LIVEKIT_URL=wss://__YOUR_PROJECT__.livekit.cloud
# LIVEKIT_API_KEY=__LK_API_KEY__
# LIVEKIT_API_SECRET=__LK_API_SECRET__
# LIVEKIT_WEBHOOK_SECRET=__LK_API_SECRET__
# CALL_ENABLE_VIDEO=true

# ── Sentry 错误聚合(可选;留空=关闭)────────────────────────────────
# LOG_AGGREGATION_PROVIDER=sentry
# SENTRY_DSN=
