# circle_be 生产/测试环境配置模板。
# 用法:复制为 .env.production,把所有 __XXX__ 占位换成真实值。
# docker-compose 会把 .env.production 挂载到容器 /app/.env.production。
# ⚠️ getServerConfig 只读此文件、不读环境变量,所以配置必须写在这里。
# ⚠️ .env.production 含密钥,切勿提交(.gitignore / .dockerignore 已排除 .env*)。

NODE_ENV=production

# ── 数据库(容器内 postgres 服务)────────────────────────────────
# 主机名用 compose 服务名 postgres;密码须与 compose 的 DB_PASSWORD 一致
DATABASE_URL="postgresql://circle:__DB_PASSWORD__@postgres:5432/circle?schema=public"

# ── Redis(内置模式;容器内服务,不暴露公网端口)────────────────────
# 密码须与 compose 的 REDIS_PASSWORD 一致;特殊字符需 URL 编码。
# 托管模式改成 rediss://default:<PASSWORD>@<HOST>:<PORT>,并设置
# REDIS_ALLOW_INSECURE=false;同时从 .env 的 COMPOSE_PROFILES 移除 bundled-redis。
REDIS_URL="redis://default:__REDIS_PASSWORD__@redis:6379"
REDIS_ALLOW_INSECURE=true
REDIS_REQUIRED=false

# ── 鉴权密钥(生产必填,≥32 字符)────────────────────────────────
# 生成:openssl rand -base64 48
SECRET="__REPLACE_32PLUS_RANDOM__"
JWT_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=30d

# ── 临时聊天分享链接签名(生产必填,≥32 字符)──────────────────────
# 即使不用临时聊天功能也必须给一个随机串,否则启动校验失败
TEMP_CHAT_LINK_SECRET="__REPLACE_32PLUS_RANDOM__"

# ── CORS(生产必填)──────────────────────────────────────────────
# 原生 app 请求无 Origin 头,会被自动放行,不受此项影响。
# 与生产 Admin Web 域名一致;多个来源用逗号分隔。
ALLOWED_ORIGINS=https://admin.example.com

# ── 服务端口 ────────────────────────────────────────────────────
APP_PORT=3000

# ── 日志 ────────────────────────────────────────────────────────
LOG_ON=true
LOG_LEVEL=info
TIMESTAMP=true
HTTP_LOG_ON=true
SLOW_REQUEST_MS=1000
BUSINESS_LOG_ON=true
EXTERNAL_LOG_ON=true
RATE_LIMIT_LOG_ON=true

# ── /metrics 保护(建议设置,否则暴露路由清单/业务指标)──────────────
METRICS_AUTH_TOKEN=__REPLACE_RANDOM__

# ── 对象存储 MinIO(容器内 minio 服务)──────────────────────────────
# 上传模块(头像/图片)需要。PUBLIC_URL 用服务器公网 IP,让 app 能下载图片。
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=__MINIO_ROOT_USER__
MINIO_SECRET_KEY=__MINIO_ROOT_PASSWORD__
MINIO_BUCKET=circle
MINIO_PUBLIC_URL=https://__API_DOMAIN__

# ── OpenIM(阶段5 部署 OpenIM 后填)──────────────────────────────────
# OPENIM_API_URL=http://__SERVER_PUBLIC_IP__:10002
# OPENIM_ADMIN_SECRET=__OPENIM_ADMIN_SECRET__
# 返回给客户端的 IM 直连地址(用服务器公网 IP)
# OPENIM_IM_WS_URL=ws://__SERVER_PUBLIC_IP__:10001
# OPENIM_IM_API_URL=http://__SERVER_PUBLIC_IP__:10002

# ── LiveKit Cloud 音视频(阶段6 注册 LiveKit Cloud 后填)──────────────
# LIVEKIT_URL=wss://__YOUR_PROJECT__.livekit.cloud
# LIVEKIT_API_KEY=__LK_API_KEY__
# LIVEKIT_API_SECRET=__LK_API_SECRET__
# LIVEKIT_WEBHOOK_SECRET=__LK_API_SECRET__
# CALL_ENABLE_VIDEO=true

# ── Sentry 错误聚合(可选;留空=关闭)────────────────────────────────
# LOG_AGGREGATION_PROVIDER=sentry
# SENTRY_DSN=
