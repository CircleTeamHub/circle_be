generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  BANNED
  DELETED
}

enum RefreshTokenAudience {
  APP
  ADMIN
}

enum EmailCodePurpose {
  REGISTER
  LOGIN
}

enum UserRole {
  ADMIN
  MEMBER
  USER
}

enum Gender {
  male
  female
  other
  unset
}

enum FriendState {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

/// How much of the owner's world a friend may see.
/// FULL = chat + moments; CHAT_ONLY = chat but hidden from the owner's moments.
enum FriendPermission {
  FULL
  CHAT_ONLY
}

enum FriendActivityType {
  REQUEST_RECEIVED
  REQUEST_SENT
  REQUEST_ACCEPTED_BY_OTHER
  REQUEST_REJECTED_BY_OTHER
  REQUEST_ACCEPTED_BY_ME
  REQUEST_REJECTED_BY_ME
  REQUEST_WITHDRAWN_BY_OTHER
}

enum NoteStatus {
  ACTIVE
  UNLISTED
  DELETED
}

enum NoteMediaType {
  IMAGE
  VIDEO
}

enum CirclePostStatus {
  ACTIVE
  ENDED
  DELETED
}

enum CircleMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum CircleMemberStatus {
  ACTIVE
  PENDING
  REJECTED
}

enum GroupSyncOperation {
  ADD_MEMBER
  REMOVE_MEMBER
}

enum GroupSyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum FriendSyncOperation {
  IMPORT_FRIEND
  DELETE_FRIEND
  ADD_BLACKLIST
  REMOVE_BLACKLIST
}

enum FriendSyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum IconAssetSourceType {
  SYSTEM
  CIRCLE
}

enum UserDisplayIconType {
  SYSTEM
  CIRCLE
}

enum SystemIconKey {
  VIP
  NEW_USER
  TOP_COLLABORATOR
  VERIFIED_PROFILE
  CIRCLE_BUILDER
  // Legacy value kept for databases that already applied the old PARTNER enum
  // migration. The service no longer emits or accepts this key.
  PARTNER
}

enum CircleCategory {
  LIFE
  FOOD
  SPORTS
  SOCIAL
  GAMING
  PHOTOGRAPHY
  WORK
  TRADE
  CUSTOM
}

enum CircleInvitationStatus {
  PENDING
  APPROVED
  REJECTED
  ADMIN_APPROVED
}

enum CircleInvitationVerifierStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TraceType {
  MOMENT
}

enum TraceVisibility {
  PRIVATE
  PUBLIC
  FRIENDS_ONLY
}

enum UserTracePreferenceType {
  HIDE
}

enum NotificationType {
  SQUAD_REQUEST_RECEIVED
  SQUAD_REQUEST_ACCEPTED
  SQUAD_REQUEST_REJECTED
  FRIEND_REQUEST_RECEIVED
  FRIEND_REQUEST_ACCEPTED
  FRIEND_REQUEST_REJECTED
  FRIEND_REQUEST_MESSAGE
  SYSTEM
  TRACE_LIKE
  TRACE_COMMENT
  COMMENT_REPLY
  CIRCLE_VERIFICATION_REQUESTED
  CIRCLE_INVITATION_APPROVED
  CIRCLE_INVITATION_REJECTED
  CIRCLE_ADMIN_OVERRIDE_APPROVED
  CIRCLE_POST_SIGNUP_CREATED
  CIRCLE_POST_AUTO_ENDED
  PROFILE_LIKE
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  RINGING
  ACTIVE
  ENDED
  CANCELED
  MISSED
  FAILED
}

enum CallParticipantStatus {
  INVITED
  JOINED
  LEFT
  REJECTED
  MISSED
}

enum CallEndReason {
  NORMAL
  CANCELED
  ALL_LEFT
  NO_ANSWER
  TIMEOUT
  NETWORK
  ERROR
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id                         String     @id @default(uuid())
  accountId                  String     @unique
  passwordHash               String
  loginSecurityCodeHash      String?
  securityCodeAttempts       Int        @default(0)
  securityCodeLockedUntil    DateTime?
  singleDeviceLoginEnabled   Boolean    @default(false)
  nickname                   String
  avatarUrl                  String?
  avatarFrame                String?
  cover                      String?
  email                      String?    @unique
  phoneNumber                String?
  wechat                     String?
  qq                         String?
  whatsup                    String?
  persona                    String?
  helloWords                 String?
  birthday                   DateTime?
  city                       String?
  region                     String?
  gender                     Gender     @default(unset)
  role                       UserRole   @default(USER)
  status                     UserStatus @default(ACTIVE)
  vipLevel                   Int        @default(0)
  creditScore                Int        @default(100)
  fancyNumber                Boolean    @default(false)
  iconPreferencesInitialized Boolean    @default(false)
  openimSynced               Boolean    @default(false)
  lastOnline                 DateTime?
  /// Set once the one-time friend-activity backfill has run for this user.
  activitiesBackfilledAt     DateTime?
  /// 收到的累计点赞总数（每人对其每天最多 +1），达阈值发放合作达人徽章。
  receivedLikeCount          Int        @default(0)
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt

  refreshTokens                     RefreshToken[]
  friendsAsUser                     Friend[]                    @relation("userFriends")
  friendsAsFriend                   Friend[]                    @relation("userFriendsTo")
  blocksIssued                      Block[]                     @relation("blocker")
  blocksReceived                    Block[]                     @relation("blocked")
  notifications                     Notification[]              @relation("toUser")
  notificationsSent                 Notification[]              @relation("fromUser")
  devicePushTokens                  DevicePushToken[]
  traces                            Trace[]
  traceComments                     TraceComment[]
  traceLikeStats                    traceLikeStat[]
  likesGiven                        UserLike[]                  @relation("userLikesGiven")
  likesReceived                     UserLike[]                  @relation("userLikesReceived")
  tracePreferences                  UserTracePreference[]
  privacySetting                    UserPrivacySetting?
  wallet                            Wallet?
  coinTransactions                  CoinTransaction[]
  coinGiftsSent                     CoinGift[]                  @relation("giftSender")
  coinGiftsReceived                 CoinGift[]                  @relation("giftRecipient")
  collections                       UserCollection[]
  circlePostSignups                 CirclePostSignup[]
  friendTags                        FriendTag[]
  friendTagAssignments              FriendTagOnFriend[]         @relation("tagOwner")
  pendingFriendTagAssignments       PendingFriendTagOnRequest[] @relation("pendingTagOwner")
  friendActivities                  FriendActivity[]            @relation("friendActivityViewer")
  friendActivitiesAuthored          FriendActivity[]            @relation("friendActivityActor")
  friendActivitiesCounterparty      FriendActivity[]            @relation("friendActivityCounterparty")
  friendRequestMessages             FriendRequestMessage[]      @relation("friendRequestMessageSender")
  friendReportsFiled                FriendReport[]              @relation("friendReportReporter")
  friendReportsReceived             FriendReport[]              @relation("friendReportTarget")
  friendReportsReviewed             FriendReport[]              @relation("friendReportReviewer")
  groupReportsFiled                 GroupReport[]               @relation("groupReportReporter")
  creditEvents                      CreditEvent[]               @relation("creditEventUser")
  creditEventsAuthored              CreditEvent[]               @relation("creditEventActor")
  notes                             Note[]
  noteShareLinks                    NoteShareLink[]
  noteGroups                        NoteGroup[]
  circles                           Circle[]
  circleMembers                     CircleMember[]
  collaborationRecognitionsReceived CollaborationRecognition[]  @relation("collaborationRecognitionRecipient")
  collaborationRecognitionsGiven    CollaborationRecognition[]  @relation("collaborationRecognitionRecognizer")
  circlePosts                       CirclePost[]
  circleInvitationsAsApplicant      CircleInvitation[]          @relation("invitationApplicant")
  circleInvitationsAsInviter        CircleInvitation[]          @relation("invitationInviter")
  circleVerifications               CircleInvitationVerifier[]  @relation("verifierUser")
  circleVerificationsAdded          CircleInvitationVerifier[]  @relation("verifierAddedBy")
  iconAssetsCreated                 IconAsset[]                 @relation("iconAssetCreator")
  displayIcons                      UserDisplayIcon[]
  conversationGroups                ConversationGroup[]
  callSessionsInitiated             CallSession[]               @relation("callInitiator")
  callParticipants                  CallParticipant[]
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  token      String    @unique
  audience   RefreshTokenAudience @default(APP)
  deviceName String?
  ip         String?
  userAgent  String?
  expiredAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Social ───────────────────────────────────────────────────────────────────

model Friend {
  id                    String                      @id @default(uuid())
  userID                String
  friendID              String
  state                 FriendState                 @default(PENDING)
  message               String?
  pendingRemarkBySender String?
  /// userID's private remark for friendID
  remarkA               String?
  /// friendID's private remark for userID
  remarkB               String?
  /// Sender-owned private description staged on the request, promoted on accept
  pendingDescriptionBySender String?
  /// userID's private description note for friendID
  descriptionA          String?
  /// friendID's private description note for userID
  descriptionB          String?
  /// Sender-owned description photo keys staged on the request, promoted on accept
  pendingPhotosBySender String[]                    @default([])
  /// userID's private description photo keys for friendID
  photosA               String[]                    @default([])
  /// friendID's private description photo keys for userID
  photosB               String[]                    @default([])
  /// Permission the sender grants the target, staged on the request
  pendingPermissionBySender FriendPermission?
  /// userID's granted permission for friendID (gates friendID seeing userID's moments)
  permissionA           FriendPermission            @default(FULL)
  /// friendID's granted permission for userID (gates userID seeing friendID's moments)
  permissionB           FriendPermission            @default(FULL)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  user                  User                        @relation("userFriends", fields: [userID], references: [id], onDelete: Cascade)
  friend                User                        @relation("userFriendsTo", fields: [friendID], references: [id], onDelete: Cascade)
  tagLinks              FriendTagOnFriend[]
  pendingTagLinks       PendingFriendTagOnRequest[]
  activities            FriendActivity[]
  messages              FriendRequestMessage[]

  @@index([userID])
  @@index([friendID])
}

// 好友申请阶段的多轮留言线程（双方 accept/reject 前的往来）。
// 接受后按序注入两人 OpenIM 会话成为聊天首屏历史。
model FriendRequestMessage {
  id        String   @id @default(uuid())
  requestId String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  request Friend @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender  User   @relation("friendRequestMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

enum FriendReportStatus {
  PENDING
  APPROVED
  REJECTED
}

model FriendReport {
  id           String             @id @default(uuid())
  reporterID   String
  targetID     String
  category     String
  description  String
  evidence     String[]           @default([])
  status       FriendReportStatus @default(PENDING)
  reviewedByID String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  reporter   User  @relation("friendReportReporter", fields: [reporterID], references: [id], onDelete: Cascade)
  target     User  @relation("friendReportTarget", fields: [targetID], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("friendReportReviewer", fields: [reviewedByID], references: [id], onDelete: SetNull)

  // Uniqueness is enforced by a partial index (see migration
  // add_friend_report_reportable_after_rejection): at most one non-REJECTED
  // report per (reporter, target, category), so a rejected report frees the
  // slot for a fresh one. Prisma can't express a partial @@unique, so it lives
  // in raw SQL and is intentionally absent here.
  @@index([reporterID, createdAt])
  @@index([targetID, createdAt])
  @@index([status, createdAt])
}

model GroupReport {
  id          String   @id @default(uuid())
  reporterID  String
  groupID     String
  circleID    String?
  category    String
  description String
  evidence    String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter User    @relation("groupReportReporter", fields: [reporterID], references: [id], onDelete: Cascade)
  circle   Circle? @relation("groupReports", fields: [circleID], references: [id], onDelete: SetNull)

  @@unique([reporterID, groupID, category])
  @@index([reporterID, createdAt])
  @@index([groupID, createdAt])
  @@index([circleID, createdAt])
}

model CreditEvent {
  id             String   @id @default(uuid())
  userID         String
  delta          Int
  scoreBefore    Int
  scoreAfter     Int
  reason         String
  sourceType     String
  sourceID       String?
  actorID        String?
  idempotencyKey String?  @unique
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User  @relation("creditEventUser", fields: [userID], references: [id], onDelete: Cascade)
  actor User? @relation("creditEventActor", fields: [actorID], references: [id], onDelete: SetNull)

  @@index([userID, createdAt])
  @@index([actorID, createdAt])
  @@index([sourceType, sourceID])
}

model GroupSyncOutbox {
  id            String             @id @default(uuid())
  operation     GroupSyncOperation
  status        GroupSyncStatus    @default(PENDING)
  groupID       String
  userID        String
  attempts      Int                @default(0)
  lastError     String?
  nextAttemptAt DateTime           @default(now())
  lockedAt      DateTime?
  processedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status, nextAttemptAt])
  @@index([groupID, userID, status])
}

model FriendSyncOutbox {
  id            String              @id @default(uuid())
  operation     FriendSyncOperation
  status        FriendSyncStatus    @default(PENDING)
  userID        String
  targetUserID  String
  attempts      Int                 @default(0)
  lastError     String?
  nextAttemptAt DateTime            @default(now())
  lockedAt      DateTime?
  processedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status, nextAttemptAt])
  @@index([userID, targetUserID, status])
}

model Note {
  id                  String     @id @default(uuid())
  ownerID             String
  groupID             String?
  title               String
  content             String?
  contentJson         Json?
  sections            Json?
  status              NoteStatus @default(ACTIVE)
  available           Boolean    @default(true)
  pinned              Boolean    @default(false)
  coverMediaID        String?    @unique
  mediaCount          Int        @default(0)
  imageCount          Int        @default(0)
  videoCount          Int        @default(0)
  // 从聊天收藏他人笔记时的来源快照（会话类型、群/发送者名片、消息定位信息）。
  // 自建笔记为 null；collectedFromNoteID 冗余成单列用于幂等去重查询。
  collectedFrom       Json?
  collectedFromNoteID String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  owner            User                  @relation(fields: [ownerID], references: [id], onDelete: Cascade)
  group            NoteGroup?            @relation(fields: [groupID], references: [id], onDelete: SetNull)
  media            NoteMedia[]           @relation("noteMediaItems")
  coverMedia       NoteMedia?            @relation("noteCoverMedia", fields: [coverMediaID], references: [id], onDelete: SetNull)
  groupMemberships NoteGroupMembership[]
  // Active collect idempotency is enforced by a raw partial unique index in
  // migration 20260702010000_add_note_collected_from. Prisma cannot model the
  // `WHERE collectedFromNoteID IS NOT NULL AND status <> 'DELETED'` predicate.

  @@index([ownerID, status, updatedAt])
  @@index([ownerID, pinned, updatedAt])
  @@index([groupID])
}

model NoteShareLink {
  id        String      @id @default(uuid())
  ownerID   String
  token     String      @unique
  title     String
  status    NoteStatus?
  group     String?
  groupID   String?
  search    String?
  noteIDs   String[]    @default([])
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  owner User @relation(fields: [ownerID], references: [id], onDelete: Cascade)

  @@index([ownerID, createdAt])
  @@index([token])
  @@index([expiresAt])
}

model NoteMedia {
  id         String        @id @default(uuid())
  noteID     String
  type       NoteMediaType
  objectKey  String
  url        String
  mimeType   String?
  size       Int?
  width      Int?
  height     Int?
  durationMs Int?
  posterUrl  String?
  sortOrder  Int
  createdAt  DateTime      @default(now())

  note         Note  @relation("noteMediaItems", fields: [noteID], references: [id], onDelete: Cascade)
  coverForNote Note? @relation("noteCoverMedia")

  @@unique([noteID, sortOrder])
  @@index([noteID, sortOrder])
}

model NoteGroup {
  id        String    @id @default(uuid())
  ownerID   String
  name      String
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  owner       User                  @relation(fields: [ownerID], references: [id], onDelete: Cascade)
  notes       Note[]
  memberships NoteGroupMembership[]

  @@index([ownerID, deletedAt, sortOrder])
}

model NoteGroupMembership {
  id        String   @id @default(uuid())
  noteID    String
  groupID   String
  createdAt DateTime @default(now())

  note  Note      @relation(fields: [noteID], references: [id], onDelete: Cascade)
  group NoteGroup @relation(fields: [groupID], references: [id], onDelete: Cascade)

  @@unique([noteID, groupID])
  @@index([groupID])
}

model FriendActivity {
  id              String             @id @default(uuid())
  requestId       String
  viewerId        String
  actorId         String
  counterpartyId  String
  type            FriendActivityType
  messageSnapshot String?
  readAt          DateTime?
  createdAt       DateTime           @default(now())
  request         Friend             @relation(fields: [requestId], references: [id], onDelete: Cascade)
  viewer          User               @relation("friendActivityViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  actor           User               @relation("friendActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  counterparty    User               @relation("friendActivityCounterparty", fields: [counterpartyId], references: [id], onDelete: Cascade)

  @@unique([requestId, viewerId, type])
  @@index([requestId])
  @@index([viewerId, createdAt])
  @@index([viewerId, readAt])
}

// Friend tags — user-defined labels like "高中同学", "同事"
model FriendTag {
  id              String                      @id @default(uuid())
  ownerID         String
  name            String
  color           String?
  createdAt       DateTime                    @default(now())
  owner           User                        @relation(fields: [ownerID], references: [id], onDelete: Cascade)
  friends         FriendTagOnFriend[]
  pendingRequests PendingFriendTagOnRequest[]

  @@unique([ownerID, name])
  @@index([ownerID])
}

// Junction: which tags an owner has applied to which friendship
model FriendTagOnFriend {
  id         String    @id @default(uuid())
  ownerID    String
  tagID      String
  friendID   String // the Friend record id
  createdAt  DateTime  @default(now())
  owner      User      @relation("tagOwner", fields: [ownerID], references: [id], onDelete: Cascade)
  tag        FriendTag @relation(fields: [tagID], references: [id], onDelete: Cascade)
  friendship Friend    @relation(fields: [friendID], references: [id], onDelete: Cascade)

  @@unique([ownerID, tagID, friendID])
  @@index([ownerID, friendID])
}

model PendingFriendTagOnRequest {
  id        String    @id @default(uuid())
  ownerID   String
  requestID String
  tagID     String
  createdAt DateTime  @default(now())
  owner     User      @relation("pendingTagOwner", fields: [ownerID], references: [id], onDelete: Cascade)
  request   Friend    @relation(fields: [requestID], references: [id], onDelete: Cascade)
  tag       FriendTag @relation(fields: [tagID], references: [id], onDelete: Cascade)

  @@unique([ownerID, requestID, tagID])
  @@index([ownerID, requestID])
  @@index([requestID])
}

model Block {
  id        String   @id @default(uuid())
  blockerID String
  blockedID String
  createdAt DateTime @default(now())
  blocker   User     @relation("blocker", fields: [blockerID], references: [id], onDelete: Cascade)
  blocked   User     @relation("blocked", fields: [blockedID], references: [id], onDelete: Cascade)

  @@unique([blockerID, blockedID])
  @@index([blockerID])
  @@index([blockedID])
}

model CallSession {
  id              String         @id @default(uuid())
  conversationID  String
  sessionType     Int
  callType        CallType
  status          CallStatus     @default(RINGING)
  livekitRoomName String         @unique
  initiatorID     String
  startedAt       DateTime?
  endedAt         DateTime?
  expiresAt       DateTime
  endedByID       String?
  endReason       CallEndReason?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  initiator    User              @relation("callInitiator", fields: [initiatorID], references: [id], onDelete: Cascade)
  participants CallParticipant[]

  @@index([conversationID, createdAt])
  @@index([initiatorID, status])
  @@index([expiresAt, status])
}

model CallParticipant {
  id          String                @id @default(uuid())
  callID      String
  userID      String
  status      CallParticipantStatus @default(INVITED)
  invitedAt   DateTime              @default(now())
  joinedAt    DateTime?
  leftAt      DateTime?
  rejectedAt  DateTime?
  missedAt    DateTime?
  lastTokenAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  call CallSession @relation(fields: [callID], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@unique([callID, userID])
  @@index([userID, status])
  @@index([callID, status])
}

// ─── Conversation Group ───────────────────────────────────────────────────────
//
// User-defined buckets for organizing chat conversations (private + group).
// Per-user, no sharing across accounts.
//   - pinnedToTabs: whether this bucket renders as a filter tab on the messages list.
//   - sortOrder: reserved for v2 drag-reorder; v1 reads by createdAt.
//
// Membership is plain `conversationID` (OpenIM string id) — we don't FK to any
// conversation table because conversations live in OpenIM, not Postgres.

model ConversationGroup {
  id           String                        @id @default(uuid())
  ownerID      String
  name         String
  sortOrder    Int                           @default(0)
  pinnedToTabs Boolean                       @default(true)
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt
  owner        User                          @relation(fields: [ownerID], references: [id], onDelete: Cascade)
  memberships  ConversationGroupMembership[]

  @@unique([ownerID, name])
  @@index([ownerID])
}

model ConversationGroupMembership {
  groupID        String
  conversationID String
  createdAt      DateTime          @default(now())
  group          ConversationGroup @relation(fields: [groupID], references: [id], onDelete: Cascade)

  @@id([groupID, conversationID])
  @@index([conversationID])
}

// ─── Trace ────────────────────────────────────────────────────────────────────

model Trace {
  id         String          @id @default(uuid())
  title      String          @default("")
  content    String          @default("")
  deleted    Boolean         @default(false)
  visibility TraceVisibility @default(PUBLIC)
  images     String[]        @default([])
  type       TraceType
  fromID     String
  likeCount  Int             @default(0)
  replyCount Int             @default(0)
  shareCount Int             @default(0)
  viewCount  Int             @default(0)
  latitude   Float?
  longitude  Float?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  from          User                  @relation(fields: [fromID], references: [id], onDelete: Cascade)
  comments      TraceComment[]
  likeStats     traceLikeStat[]
  preferences   UserTracePreference[]
  notifications Notification[]

  // Feed keyset pagination orders by (createdAt DESC, id DESC) filtered by
  // fromID. Including the id tiebreaker keeps the index aligned with the cursor
  // ordering and still covers plain fromID lookups.
  @@index([fromID, createdAt(sort: Desc), id(sort: Desc)])
}

model TraceComment {
  id        String   @id @default(uuid())
  content   String   @default("")
  images    String[] @default([])
  deleted   Boolean  @default(false)
  private   Boolean  @default(false)
  traceID   String
  userID    String
  replyToID String?
  parentID  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trace    Trace          @relation(fields: [traceID], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userID], references: [id], onDelete: Cascade)
  parent   TraceComment?  @relation("CommentParent", fields: [parentID], references: [id])
  children TraceComment[] @relation("CommentParent")
  replyTo  TraceComment?  @relation("CommentReply", fields: [replyToID], references: [id])
  replies  TraceComment[] @relation("CommentReply")

  fromNotifications Notification[] @relation("fromReply")
  toNotifications   Notification[] @relation("toReply")

  @@index([traceID])
  @@index([userID])
}

model traceLikeStat {
  id        String   @id @default(uuid())
  traceID   String
  userID    String
  deleted   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  trace     Trace    @relation(fields: [traceID], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@unique([traceID, userID])
}

model UserTracePreference {
  id        String                  @id @default(uuid())
  userID    String
  traceID   String
  type      UserTracePreferenceType
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  trace     Trace                   @relation(fields: [traceID], references: [id], onDelete: Cascade)
  user      User                    @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@unique([userID, traceID])
  @@index([userID])
  @@index([traceID])
}

model UserPrivacySetting {
  id                      String   @id @default(uuid())
  userID                  String   @unique
  messageSelfDestructDays Int      @default(2)
  momentsVisibility       String   @default("ALL")
  allowStrangerMessages   Boolean  @default(true)
  showPhone               Boolean  @default(false)
  showWechat              Boolean  @default(true)
  showQQ                  Boolean  @default(true)
  addMeByAccount          Boolean  @default(true)
  addMeByPhone            Boolean  @default(false)
  addMeByQrCode           Boolean  @default(true)
  addMeByGroup            Boolean  @default(true)
  callPermission          String   @default("EVERYONE")
  groupInvitePermission   String   @default("EVERYONE")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@index([userID])
}

// ─── Coin / Wallet ────────────────────────────────────────────────────────────

enum CoinTxType {
  RECHARGE // top-up by admin / payment
  GIFT_SENT // deducted when sending a gift
  GIFT_RECEIVED // credited when receiving a gift
  REFUND // admin refund
  PURCHASE // deducted when buying membership or mall items
  ADJUSTMENT // manual admin correction
}

enum CollectionType {
  CHAT
  VIDEO
  VOICE
  MESSAGE
  NOTE
}

model Wallet {
  id        String   @id @default(uuid())
  userID    String   @unique
  balance   Int      @default(0) // stored in smallest unit (1 coin = 1)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userID], references: [id], onDelete: Cascade)
}

model CoinTransaction {
  id        String     @id @default(uuid())
  userID    String
  type      CoinTxType
  amount    Int // positive = credit, negative = debit
  balance   Int // balance after this tx
  note      String?
  relatedID String? // e.g. CoinGift.id for gift txs
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@index([userID, createdAt])
}

model CoinGift {
  id             String   @id @default(uuid())
  senderID       String
  recipientID    String
  amount         Int
  message        String?
  /// Client-supplied Idempotency-Key — a retry of the same gift reuses it
  /// and is rejected by the unique constraint instead of double-charging.
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  sender         User     @relation("giftSender", fields: [senderID], references: [id], onDelete: Cascade)
  recipient      User     @relation("giftRecipient", fields: [recipientID], references: [id], onDelete: Cascade)

  @@index([senderID])
  @@index([recipientID])
}

model UserCollection {
  id        String         @id @default(uuid())
  userID    String
  type      CollectionType
  title     String
  summary   String?
  sourceID  String?
  payload   Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@index([userID, type, createdAt])
}

model IconAsset {
  id          String              @id @default(uuid())
  name        String
  sourceType  IconAssetSourceType
  imageUrl    String?
  circleID    String?
  createdByID String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  circle            Circle?  @relation("circleIconAssets", fields: [circleID], references: [id], onDelete: Cascade)
  createdBy         User?    @relation("iconAssetCreator", fields: [createdByID], references: [id], onDelete: SetNull)
  currentForCircles Circle[] @relation("currentCircleIcon")

  @@index([circleID])
  @@index([sourceType])
}

model UserDisplayIcon {
  id            String              @id @default(uuid())
  userID        String
  displayType   UserDisplayIconType
  systemKey     SystemIconKey?
  systemVariant String?
  circleID      String?
  sortOrder     Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user   User    @relation(fields: [userID], references: [id], onDelete: Cascade)
  circle Circle? @relation(fields: [circleID], references: [id], onDelete: Cascade)

  @@unique([userID, systemKey, systemVariant])
  @@unique([userID, circleID])
  @@index([userID, sortOrder])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id               String           @id @default(uuid())
  content          String           @default("")
  deleted          Boolean          @default(false)
  read             Boolean          @default(false)
  type             NotificationType
  toUserID         String?
  fromUserID       String
  fromTraceID      String?
  fromReplyID      String?
  toReplyID        String?
  fromCircleID     String?
  fromCirclePostID String?
  fromInvitationID String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  toUser         User?             @relation("toUser", fields: [toUserID], references: [id])
  fromUser       User              @relation("fromUser", fields: [fromUserID], references: [id])
  fromTrace      Trace?            @relation(fields: [fromTraceID], references: [id])
  fromReply      TraceComment?     @relation("fromReply", fields: [fromReplyID], references: [id])
  toReply        TraceComment?     @relation("toReply", fields: [toReplyID], references: [id])
  fromCircle     Circle?           @relation(fields: [fromCircleID], references: [id])
  fromCirclePost CirclePost?       @relation(fields: [fromCirclePostID], references: [id])
  fromInvitation CircleInvitation? @relation(fields: [fromInvitationID], references: [id])

  @@index([fromUserID, toUserID])
  @@index([toUserID])
}

model DevicePushToken {
  id         String    @id @default(uuid())
  token      String    @unique
  provider   String
  platform   String
  projectId  String?
  appVersion String?
  disabledAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  userID String
  user   User   @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@index([userID])
  @@index([provider, platform])
}

// ─── Circle Plaza ────────────────────────────────────────────────────────────

model Circle {
  id                    String   @id @default(uuid())
  name                  String
  description           String   @default("")
  avatarUrl             String?
  cover                 String?
  ownerID               String
  currentIconAssetID    String?
  cities                String[] @default([])
  isPublic              Boolean  @default(true)
  categories            String[] @default([])
  rules                 String   @default("")
  tags                  String[] @default([])
  joinVipRestriction    Int?
  joinCreditRestriction Int?
  joinFancyRestriction  Boolean  @default(false)
  maxMembers            Int?
  memberCanPost         Boolean  @default(true)
  groupID               String?  @unique
  memberCount           Int      @default(0)
  postCount             Int      @default(0)
  deleted               Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  owner             User               @relation(fields: [ownerID], references: [id], onDelete: Cascade)
  currentIconAsset  IconAsset?         @relation("currentCircleIcon", fields: [currentIconAssetID], references: [id], onDelete: SetNull)
  iconAssets        IconAsset[]        @relation("circleIconAssets")
  posts             CirclePost[]
  postLinks         CirclePostCircle[]
  members           CircleMember[]
  invitations       CircleInvitation[]
  notifications     Notification[]
  displaySelections UserDisplayIcon[]
  groupReports      GroupReport[]      @relation("groupReports")

  @@index([ownerID])
}

model CircleMember {
  id        String             @id @default(uuid())
  userID    String
  circleID  String
  role      CircleMemberRole   @default(MEMBER)
  status    CircleMemberStatus @default(PENDING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user   User   @relation(fields: [userID], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleID], references: [id], onDelete: Cascade)

  @@unique([userID, circleID])
  @@index([circleID])
}

model CirclePost {
  id                        String           @id @default(uuid())
  content                   String           @default("")
  images                    String[]         @default([])
  tags                      String[]         @default([])
  // `city` 保留为「主城市」(= cities[0]) 兼容旧数据/旧客户端；`cities` 是多选来源。
  city                      String?
  cities                    String[]         @default([])
  isHorn                    Boolean          @default(false)
  noteID                    String?
  vipRestriction            Int?
  creditRestriction         Int?
  fancyRestriction          Boolean          @default(false)
  viewCount                 Int              @default(0)
  signupCount               Int              @default(0)
  signupVipRestriction      Int?
  signupCreditRestriction   Int?
  signupFancyRestriction    Boolean          @default(false)
  status                    CirclePostStatus @default(ACTIVE)
  endedAt                   DateTime?
  collaborationRecognizedAt DateTime?
  expiresAt                 DateTime?
  authorID                  String
  circleID                  String
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  author                    User                       @relation(fields: [authorID], references: [id], onDelete: Cascade)
  // `circle`/`circleID` 保留为「主圈子」(= circleIds[0])，兼容旧查询/计数；
  // `circleLinks` 是多选真源（含主圈子），feed 可见性/筛选走它。
  circle                    Circle                     @relation(fields: [circleID], references: [id], onDelete: Cascade)
  circleLinks               CirclePostCircle[]
  signups                   CirclePostSignup[]
  collaborationRecognitions CollaborationRecognition[]
  notifications             Notification[]

  @@index([circleID, createdAt(sort: Desc)])
  @@index([authorID])
  @@index([city, createdAt(sort: Desc)])
  @@index([status, expiresAt])
  // Plaza feed keyset: status='ACTIVE' equality + ORDER BY (createdAt DESC, id
  // DESC) is served as a pure index scan (no heapsort). Status-aware, so it
  // stays efficient as ENDED/DELETED posts accumulate. Verified ~135x faster
  // than the heapsort baseline on a 40k-post / 50-circle EXPLAIN ANALYZE.
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
}

// 一条动态 ↔ 多个圈子的关联表（含主圈子）。一条动态可同时出现在多个圈子的广场。
model CirclePostCircle {
  id        String   @id @default(uuid())
  postID    String
  circleID  String
  createdAt DateTime @default(now())

  post   CirclePost @relation(fields: [postID], references: [id], onDelete: Cascade)
  circle Circle     @relation(fields: [circleID], references: [id], onDelete: Cascade)

  @@unique([postID, circleID])
  // 按圈子拉取广场 feed 的主查询路径（circleID → 该圈子的所有动态）。
  @@index([circleID, postID])
}

model CirclePostSignup {
  id           String    @id @default(uuid())
  postID       String
  userID       String
  seenByAuthor Boolean   @default(false)
  seenAt       DateTime?
  createdAt    DateTime  @default(now())

  post CirclePost @relation(fields: [postID], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@unique([postID, userID])
  @@index([postID])
  @@index([userID])
  @@index([postID, seenByAuthor])
}

model CollaborationRecognition {
  id           String    @id @default(uuid())
  recipientID  String
  recognizerID String
  circlePostID String?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  recipient  User        @relation("collaborationRecognitionRecipient", fields: [recipientID], references: [id], onDelete: Cascade)
  recognizer User        @relation("collaborationRecognitionRecognizer", fields: [recognizerID], references: [id], onDelete: Cascade)
  circlePost CirclePost? @relation(fields: [circlePostID], references: [id], onDelete: SetNull)

  @@unique([circlePostID, recipientID])
  @@index([recipientID, revokedAt])
  @@index([recognizerID, createdAt])
  @@index([circlePostID])
}

model CircleInvitation {
  id            String                 @id @default(uuid())
  circleID      String
  applicantID   String
  inviterID     String
  requiredCount Int                    @default(10)
  approvedCount Int                    @default(0)
  status        CircleInvitationStatus @default(PENDING)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  circle        Circle                     @relation(fields: [circleID], references: [id], onDelete: Cascade)
  applicant     User                       @relation("invitationApplicant", fields: [applicantID], references: [id], onDelete: Cascade)
  inviter       User                       @relation("invitationInviter", fields: [inviterID], references: [id], onDelete: Cascade)
  verifiers     CircleInvitationVerifier[]
  notifications Notification[]

  @@index([circleID, status])
  @@index([applicantID])
}

model CircleInvitationVerifier {
  id           String                         @id @default(uuid())
  invitationID String
  verifierID   String
  addedByID    String
  status       CircleInvitationVerifierStatus @default(PENDING)
  respondedAt  DateTime?
  createdAt    DateTime                       @default(now())

  invitation CircleInvitation @relation(fields: [invitationID], references: [id], onDelete: Cascade)
  verifier   User             @relation("verifierUser", fields: [verifierID], references: [id], onDelete: Cascade)
  addedBy    User             @relation("verifierAddedBy", fields: [addedByID], references: [id], onDelete: Cascade)

  @@unique([invitationID, verifierID])
  @@index([verifierID, status])
}

enum TempChatStatus {
  ACTIVE
  ENDED
  EXPIRED
}

model TempChat {
  id         String         @id @default(uuid())
  groupId    String         @unique
  hostUserId String
  title      String         @default("临时聊天")
  status     TempChatStatus @default(ACTIVE)
  maxMembers Int            @default(50)
  expiresAt  DateTime
  endedAt    DateTime?
  cleanupLockedAt    DateTime?
  cleanupGroupDismissedAt DateTime?
  cleanupCompletedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  guests TempChatGuest[]

  @@index([status, expiresAt])
  @@index([hostUserId])
}

model TempChatGuest {
  id          String   @id @default(uuid())
  tempChatId  String
  imUserId    String   @unique
  displayName String
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  cleanedUp   Boolean  @default(false)
  provisioningFailedAt DateTime?

  tempChat TempChat @relation(fields: [tempChatId], references: [id], onDelete: Cascade)

  @@index([tempChatId])
}

model EmailVerificationCode {
  id         String           @id @default(cuid())
  email      String
  codeHash   String
  purpose    EmailCodePurpose
  expiresAt  DateTime
  attempts   Int              @default(0)
  consumedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([email, purpose])
}

/// 用户对用户的点赞：每人对同一目标「每天」最多一条（likedOn 为日期，唯一约束防当日重复）。
/// 被赞总数累计在 User.receivedLikeCount，达阈值发放合作达人徽章。
model UserLike {
  id         String   @id @default(uuid())
  fromUserID String
  toUserID   String
  likedOn    DateTime @db.Date
  createdAt  DateTime @default(now())

  fromUser User @relation("userLikesGiven", fields: [fromUserID], references: [id], onDelete: Cascade)
  toUser   User @relation("userLikesReceived", fields: [toUserID], references: [id], onDelete: Cascade)

  @@unique([fromUserID, toUserID, likedOn])
  @@index([toUserID])
  // Composite backs the per-day quota count (WHERE fromUserID = ? AND likedOn = ?);
  // its fromUserID prefix also serves any fromUserID-only lookup.
  @@index([fromUserID, likedOn])
}
