# Environment for the monitoring stack (monitoring/docker-compose.yml).
#
#   cp monitoring/.env.example monitoring/.env
#
# docker compose reads `.env` from the directory holding the compose file, so
# this must live at monitoring/.env. It is gitignored — never commit real values.

# Grafana admin login. The password has NO default: compose refuses to start
# until it is set, so a fresh volume can never be seeded with admin/admin.
# Generate one:  openssl rand -base64 24
#
# NOTE: this only seeds the admin user on the FIRST boot of the grafana_data
# volume. On a volume that already exists it is silently ignored — reset in
# place instead (see README.md), do not `down -v`.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ── Production only (monitoring/docker-compose.prod.yml) ────────────────────
# The existing Docker network the circle_be app stack runs on, which Prometheus
# joins to reach the backend. Default matches docker-compose.prod.yml's
# `name: circle-be` project, whose default network is circle-be_default.
# Only set this if you run the app stack under a different project name.
# CIRCLE_BE_NETWORK=circle-be_default
