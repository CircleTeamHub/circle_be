# Copy to .env.backup and fill in. NEVER commit the filled-in file.
#   cp .env.backup.example .env.backup && chmod 600 .env.backup
#
# Read by docker-compose.backup.yml (postgres, backup, backup_mongo).
# Full setup — including the buckets and credentials you must create yourself —
# is in docs/backups.md. Read that first; this file is only the value list.
#
# There is deliberately NO default for any credential in this file. A default
# credential is a published credential: the upstream openim-docker stack ships
# openIM123 as the default for four separate secrets, and that is precisely the
# pattern this file refuses to copy. Every value below is either blank or a
# generate-this-yourself command.

# ─────────────────────────────────────────────────────────────────────────────
# 1. OFF-HOST DESTINATION (S3-compatible: Cloudflare R2, AWS S3, ...)
# ─────────────────────────────────────────────────────────────────────────────
# A backup on the same box is not a backup. pg_data and minio_data are docker
# volumes on ONE host: a single `docker compose down -v` or one disk failure
# destroys the business data and every chat message at the same instant. This
# destination MUST be a different provider/account, not another volume.
#
# These credentials MUST NOT be the app's MinIO keys, and MUST be scoped to the
# backup bucket alone. If the app is compromised, the attacker must not be able
# to reach — let alone delete — the backups. See docs/backups.md for the exact
# bucket policy / API-token scope to create.
#
# R2:  https://<account-id>.r2.cloudflarestorage.com   (BACKUP_S3_REGION=auto)
# AWS: https://s3.<region>.amazonaws.com               (BACKUP_S3_REGION=<region>)
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=
BACKUP_S3_KEY=
BACKUP_S3_KEY_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# 2. ENCRYPTION AT REST
# ─────────────────────────────────────────────────────────────────────────────
# pgBackRest repo passphrase. Encrypts the whole Postgres repo client-side,
# before anything leaves the host.
#   openssl rand -base64 48
# LOSING THIS MEANS LOSING EVERY POSTGRES BACKUP — it is not recoverable from
# the repo. Store it in a password manager, off this machine, today.
BACKUP_PG_CIPHER_PASS=

# age PUBLIC key that the Mongo dump is encrypted to. Generate the keypair on
# your workstation, NOT on the server:
#   age-keygen -o circle-backup-age.key    # keep this file OFF the server
#   grep 'public key' circle-backup-age.key
# Only the public key goes here (it starts with age1...), so a full compromise
# of the server cannot decrypt any existing Mongo backup. The private key is
# needed only at restore time (restore-mongo.sh --identity).
BACKUP_AGE_RECIPIENT=

# ─────────────────────────────────────────────────────────────────────────────
# 3. POSTGRES (source)
# ─────────────────────────────────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_DB in docker-compose.prod.yml.
BACKUP_PG_USER=circle
BACKUP_PG_DATABASE=circle
# Number of full backups kept. With a weekly full that is ~8 weeks of history.
# MUST stay LONGER than any object-lock/immutability window you set on the
# destination, or `pgbackrest expire` will try to delete still-locked objects
# and fail forever. See docs/backups.md.
BACKUP_PG_RETENTION_FULL=8

# ─────────────────────────────────────────────────────────────────────────────
# 4. MINIO (source objects: avatars, chat attachments, note media)
# ─────────────────────────────────────────────────────────────────────────────
# Reaches the app's MinIO over the compose network. These only ever need READ
# access to the bucket — create a dedicated read-only MinIO user rather than
# reusing MINIO_ROOT_USER (docs/backups.md shows the policy).
BACKUP_MINIO_ENDPOINT=http://minio:9000
BACKUP_MINIO_ACCESS_KEY=
BACKUP_MINIO_SECRET_KEY=
BACKUP_MINIO_BUCKET=circle

# ─────────────────────────────────────────────────────────────────────────────
# 5. OPENIM MONGO (every chat message) — only for the openim-backup profile
# ─────────────────────────────────────────────────────────────────────────────
# OpenIM runs as its own compose stack (openim-docker) and holds ALL chat
# history in Mongo. It is the store everybody forgets. Nothing about the OpenIM
# checkout is modified: we join its network and read with credentials you set.
#
# IMPORTANT: openim-docker ships openIM123 as its default Mongo password. If
# that is still what your deployment uses, change it there first — otherwise
# this backup is protected by a password published in a public repo.
#
# The username/password come from the openim-docker .env (MONGO_OPENIM_USERNAME
# / MONGO_OPENIM_PASSWORD). Host `mongo` resolves on the OpenIM network.
# BACKUP_MONGO_URI=mongodb://<user>:<pass>@mongo:27017/openim_v3?authSource=openim_v3
BACKUP_MONGO_URI=
# Best-effort pruning of old dumps. Leave blank to rely on a bucket lifecycle
# rule on the mongo/ prefix instead (safe there — dumps are independent files).
BACKUP_MONGO_RETENTION_DAYS=35
# Floor for a plausible dump, in bytes. A run that uploads less than this is
# treated as a failed backup and the object is deleted again, so that a later
# `restore-mongo.sh` (which defaults to "newest object under mongo/") can never
# select an empty archive. age adds ~200B of header+MAC, so the floor only has
# to clear that. Raise it if your Mongo is never small.
# BACKUP_MONGO_MIN_BYTES=1024
# Docker network of the openim-docker stack. Check with: docker network ls
# OPENIM_NETWORK=openim-docker_openim

# ─────────────────────────────────────────────────────────────────────────────
# 6. SCHEDULES (cron syntax, container TZ = UTC)
# ─────────────────────────────────────────────────────────────────────────────
# Defaults are baked into deploy/backup/entrypoint.sh; override only if needed.
# WAL archiving is continuous and is NOT on this list — it is driven by
# archive_timeout in docker-compose.backup.yml, and it is what actually buys the
# RPO. These jobs only bound how much WAL a restore has to replay (i.e. RTO).
# BACKUP_CRON_PG_FULL=0 3 * * 0
# BACKUP_CRON_PG_DIFF=0 3 * * 1-6
# pg-incr is supported but NOT scheduled by default: restoring an incremental
# needs the full + every incremental since, while a differential needs full + 1.
# That is the RTO trade-off documented above. To use it you must also swap
# pg-diff for pg-incr in the backup service's BACKUP_JOBS (docker-compose.backup.yml).
# BACKUP_CRON_PG_INCR=0 3 * * 1-6
# BACKUP_CRON_MINIO=*/15 * * * *
# Hourly, matching the default in entrypoint.sh. Do NOT make this daily: each
# run is a FULL dump and there is no oplog, so chat-history RPO is exactly this
# interval — daily means losing up to 24h of messages. See docs/backups.md
# "RPO gap: chat history".
# BACKUP_CRON_MONGO=0 * * * *
# BACKUP_CRON_CHECK=17 * * * *
# check.sh fails if no chat-history dump landed within this many hours. Must be
# comfortably larger than BACKUP_CRON_MONGO's interval, or the check flaps.
# BACKUP_CHECK_MONGO_MAX_AGE_H=3
