{
  email {$ACME_EMAIL}
}

{$API_DOMAIN} {
  @metrics path /metrics /metrics/*
  handle @metrics {
    respond 404
  }

  handle /circle/* {
    reverse_proxy minio:9000
  }

  handle {
    reverse_proxy {$CIRCLE_BE_UPSTREAM:circle_be}:3000
  }
}

{$ADMIN_DOMAIN} {
  handle /api/* {
    reverse_proxy {$CIRCLE_BE_UPSTREAM:circle_be}:3000
  }

  handle {
    reverse_proxy admin_web:80
  }
}
