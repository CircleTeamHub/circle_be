# 异地数据库备份配置模板(可选功能)。
#
# 用法:在**服务器上**复制到 $HOME/.circle_be_backup.env,把 __XXX__ 占位换成
# 真实值,然后 chmod 600。完整开通步骤见 DEPLOY.md §6「异地备份」。
#
#   cp deploy/backup.env.example ~/.circle_be_backup.env
#   chmod 600 ~/.circle_be_backup.env
#
# ⚠️ 必须放在仓库目录**之外**:发版用 rsync --delete 同步仓库,放进仓库里会被
#    下一次发版删掉。$HOME 不在同步范围内。
# ⚠️ 不配置(文件不存在)= 功能关闭,发版行为与从前完全一致,不报错。
# ⚠️ 这里的凭证**不能**复用应用自己的 MINIO_ACCESS_KEY / MINIO_SECRET_KEY。
#    整件事的前提就是:这台机器被入侵时,攻击者不能删掉备份。

# ── 目标存储桶(填了才启用)────────────────────────────────────────
BACKUP_OFFSITE_S3_BUCKET=__BUCKET_NAME__

# 非 AWS S3 的 S3 兼容端点。用 AWS S3 就整行删掉/留空。
#   Cloudflare R2   https://__ACCOUNT_ID__.r2.cloudflarestorage.com
#   Backblaze B2    https://s3.__REGION__.backblazeb2.com
BACKUP_OFFSITE_S3_ENDPOINT=__S3_ENDPOINT__

# 对象前缀(默认 circle_be)。多个环境共用一个桶时用它区分。
# BACKUP_OFFSITE_S3_PREFIX=circle_be

# 默认 auto —— R2 / B2 / MinIO 用 auto 即可;**AWS S3 必须填桶所在 region**。
# BACKUP_OFFSITE_S3_REGION=auto

# ── 只写凭证 ────────────────────────────────────────────────────────
# 权限只要 s3:PutObject(+ s3:AbortMultipartUpload)。不要给 Delete/Get/List;
# 桶要开版本控制。确切的策略 JSON 见 DEPLOY.md §6。
AWS_ACCESS_KEY_ID=__WRITE_ONLY_ACCESS_KEY__
AWS_SECRET_ACCESS_KEY=__WRITE_ONLY_SECRET_KEY__

# ── 加密公钥 ────────────────────────────────────────────────────────
# age 公钥(age1 开头),空格分隔可填多个 —— 强烈建议至少两把:一把日常用,
# 一把离线保管的 break-glass 备用钥。任何一把私钥都能独立解密。
#
# ⚠️ 这里只放**公钥**。私钥(AGE-SECRET-KEY-1... )绝不能出现在这台机器上,
#    否则入侵者连备份一起解密,异地副本的意义就没了。脚本会拒绝私钥。
BACKUP_OFFSITE_AGE_RECIPIENTS="age1__PUBLIC_KEY_1__ age1__PUBLIC_KEY_2__"

# 上传超时(秒,默认 900)。超时只是放弃这次上传,不影响发版。
# BACKUP_OFFSITE_TIMEOUT_SECONDS=900
