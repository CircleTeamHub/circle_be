# Copy to .env.development / .env.production / .env.test and fill in.
# NEVER commit a file containing real secrets — only .env.example is tracked.

NODE_ENV=development

# Database (PostgreSQL) — required unless ALLOW_START_WITHOUT_DB=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT secret — REQUIRED. Use a long random string (>= 32 chars in production).
# Generate via: `openssl rand -base64 48`
SECRET="replace-with-long-random-string"
JWT_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=30d

# Logging
LOG_ON=true
LOG_LEVEL=info
TIMESTAMP=true
HTTP_LOG_ON=true
SLOW_REQUEST_MS=1000
BUSINESS_LOG_ON=true
EXTERNAL_LOG_ON=true
RATE_LIMIT_LOG_ON=true

# Error aggregation (optional) — forwards unhandled 5xx errors to Sentry.
# Disabled by default. Set provider=sentry AND a dsn to enable; without a dsn it
# stays a no-op. Only 5xx errors are sent, with sanitized request tags (request
# id, method, path, status) — never bodies, headers, cookies, or tokens.
# LOG_AGGREGATION_PROVIDER=sentry
# SENTRY_DSN=https://<public-key>@<host>/<project-id>
# SENTRY_ENVIRONMENT=production   # optional, defaults to NODE_ENV
# SENTRY_RELEASE=circle-be@1.0.0  # optional, for release health

# Protect the Prometheus /metrics endpoint. When set, scrapers must send
# `Authorization: Bearer <token>`. Leave unset only if /metrics is reachable
# from a trusted network alone — the exposition format reveals the route
# inventory, business-event rates, and process stats.
# METRICS_AUTH_TOKEN=change-me-to-a-long-random-string

# Server
APP_PORT=3000

# Production Docker Compose / edge proxy
DB_PASSWORD=replace-with-postgres-password
MINIO_ROOT_USER=replace-with-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-minio-root-password
REDIS_PASSWORD=replace-with-redis-password
COMPOSE_PROFILES=bundled-redis
API_DOMAIN=api.example.com
ADMIN_DOMAIN=admin.example.com
ACME_EMAIL=admin@example.com

# Redis provides the WS backplane, shared limits and cache. Production defaults
# to degraded startup for availability; set REDIS_REQUIRED=true for fail-fast.
# Local development: REDIS_URL=redis://localhost:6379
# Bundled production: REDIS_URL=redis://default:<REDIS_PASSWORD>@redis:6379
# REDIS_ALLOW_INSECURE=true  # only for trusted private networks
# REDIS_REQUIRED=false       # set true only when startup must fail without Redis
# Managed production: REDIS_URL=rediss://default:<PASSWORD>@cache.example.com:6380
# Remove bundled-redis from COMPOSE_PROFILES and set REDIS_ALLOW_INSECURE=false.

# CORS — REQUIRED in production. Comma-separated list of allowed origins.
# In dev/test, localhost and LAN IPs are auto-allowed in addition.
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Degraded startup (dev only) — allow boot when DATABASE_URL is missing or unreachable
# ALLOW_START_WITHOUT_DB=true
# PRISMA_SKIP_CONNECT_ON_BOOT=true

# OpenIM (optional)
# OPENIM_API_URL=http://localhost:10002
# OPENIM_ADMIN_SECRET=replace-me

# OpenIM history store (Mongo) — required for the chat-history restore endpoint.
# Provide OPENIM_MONGO_URI, or the address (+ optional credentials) below.
# Falls back to MONGO_* equivalents when the OPENIM_* form is unset.
# OPENIM_MONGO_URI=mongodb://user:pass@localhost:27017/openim_v3?authSource=openim_v3
# OPENIM_MONGO_ADDRESS=localhost:27017
# OPENIM_MONGO_USERNAME=
# OPENIM_MONGO_PASSWORD=
# OPENIM_MONGO_DATABASE=openim_v3
# Max message shards scanned per restore request (default 20, clamped to 1..500).
# OPENIM_HISTORY_MAX_SHARD_DOCS=20

# Temp-chat feature (optional — feature is disabled if TEMP_CHAT_LINK_SECRET is empty)
# TEMP_CHAT_WEB_BASE=https://chat.example.com
# TEMP_CHAT_LINK_SECRET=replace-with-32-plus-char-random-secret
# TEMP_CHAT_DEFAULT_TTL_MINUTES=4320
# TEMP_CHAT_MAX_TTL_MINUTES=10080
# TEMP_CHAT_MAX_MEMBERS=50
# Note share links. Defaults to TEMP_CHAT_WEB_BASE when unset.
# NOTE_SHARE_WEB_BASE=https://circle.im
# OpenIM client-facing URLs returned to the web guest client
# OPENIM_IM_WS_URL=wss://your-openim-host:10001
# OPENIM_IM_API_URL=https://your-openim-host:10002

# MinIO / S3 (required when upload module is in use)
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=replace-me
# MINIO_SECRET_KEY=replace-me
# MINIO_BUCKET=circle
# MINIO_PUBLIC_URL=http://localhost:9000
