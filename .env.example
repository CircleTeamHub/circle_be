# Copy to .env.development / .env.production / .env.test and fill in.
# NEVER commit a file containing real secrets — only .env.example is tracked.

NODE_ENV=development

# Database (PostgreSQL) — required unless ALLOW_START_WITHOUT_DB=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT secret — REQUIRED. Use a long random string (>= 32 chars in production).
# Generate via: `openssl rand -base64 48`
SECRET="replace-with-long-random-string"
JWT_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=30d

# Logging
LOG_ON=true
LOG_LEVEL=info
TIMESTAMP=true
HTTP_LOG_ON=true
SLOW_REQUEST_MS=1000
BUSINESS_LOG_ON=true
EXTERNAL_LOG_ON=true
RATE_LIMIT_LOG_ON=true

# Server
APP_PORT=3000

# CORS — REQUIRED in production. Comma-separated list of allowed origins.
# In dev/test, localhost and LAN IPs are auto-allowed in addition.
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Degraded startup (dev only) — allow boot when DATABASE_URL is missing or unreachable
# ALLOW_START_WITHOUT_DB=true
# PRISMA_SKIP_CONNECT_ON_BOOT=true

# OpenIM (optional)
# OPENIM_API_URL=http://localhost:10002
# OPENIM_ADMIN_SECRET=replace-me

# MinIO / S3 (required when upload module is in use)
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=replace-me
# MINIO_SECRET_KEY=replace-me
# MINIO_BUCKET=circle
# MINIO_PUBLIC_URL=http://localhost:9000
