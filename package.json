{
  "name": "nestjs-demo",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production nest build",
    "postbuild": "node scripts/copy-generated-client.js",
    "prestart:dev": "mkdir -p dist/src && rm -rf dist/src/generated && ln -s \"$(pwd)/src/generated\" dist/src/generated",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "ts-node src/main.ts",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --maxWorkers=1",
    "test:e2e:watch": "jest --config ./test/jest-e2e.json --maxWorkers=1 --watch",
    "test:redis": "bash scripts/test-redis-integration.sh",
    "test:redis:compose": "bash scripts/test-redis-compose.sh",
    "test:minio": "bash scripts/test-minio-integration.sh",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed:admin": "node scripts/seed-admin-user.js",
    "sentry:smoke": "cross-env NODE_ENV=development ts-node scripts/sentry-smoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@casl/ability": "^6.3.2",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.0.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "@sentry/node": "^10.61.0",
    "@types/ws": "^8.18.1",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "joi": "^18.1.2",
    "livekit-server-sdk": "^2.15.4",
    "module-alias": "^2.2.2",
    "mongodb": "^6.21.0",
    "nest-winston": "^1.10.2",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "jest": "30.3.0",
    "pactum": "^3.3.1",
    "prettier": "^3.8.1",
    "prisma": "^7.0.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^6.0.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "setupFiles": [
      "<rootDir>/jest-env.setup.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 28,
        "branches": 17,
        "functions": 18,
        "lines": 70
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/"
    ],
    "moduleNameMapper": {
      "^src(.*)$": "<rootDir>/$1"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "@scarf/scarf",
      "argon2",
      "prisma",
      "unrs-resolver"
    ]
  },
  "_moduleAliases": {
    "@root": ".",
    "src": "src/",
    "@/": "src/"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "find-my-way": "^9.7.0",
    "multer": "^2.2.0",
    "picomatch": "^4.0.4"
  }
}
